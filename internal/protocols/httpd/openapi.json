        }
      }
    },
    "/api/v1/auth/oidc/start": {
      "get": {
        "tags": ["auth"],
        "summary": "Start an OIDC login flow",
        "description": "Starts the server-brokered OpenID Connect authorization code flow with PKCE. The endpoint redirects by default, or returns JSON when the client sends `Accept: application/json`.",
        "operationId": "startOIDCLogin",
        "parameters": [
          {
            "name": "return_to",
            "in": "query",
            "description": "Local path to redirect back to after the OIDC callback completes.",
            "schema": {
              "type": "string",
              "default": "/client"
            }
          },
          {
            "name": "role",
            "in": "query",
            "description": "Requested role hint for the OIDC session.",
            "schema": {
              "type": "string",
              "enum": ["admin", "user"],
              "default": "user"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OIDC redirect metadata for non-browser clients.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OIDCStartResponse"
                }
              }
            }
          },
          "302": {
            "description": "Redirects the browser to the configured OIDC provider authorization endpoint.",
            "headers": {
              "Location": {
                "description": "OIDC provider authorization URL.",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "404": {
            "description": "OIDC is not enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to initialize the OIDC flow.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/oidc/callback": {
      "get": {
        "tags": ["auth"],
        "summary": "Complete an OIDC login flow",
        "description": "Consumes the OIDC authorization response, provisions or loads the mapped account, issues the same bearer token format used by password login, and redirects back to the requested local route with token details in the query string.",
        "operationId": "completeOIDCLogin",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "description": "Opaque state returned by the start endpoint.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code",
            "in": "query",
            "description": "Authorization code returned by the OIDC provider.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "error",
            "in": "query",
            "description": "OIDC provider error returned instead of a code.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirects back to `/client` or `/admin` with `token`, `token_type`, `username`, and `role` query parameters.",
            "headers": {
              "Location": {
                "description": "Local redirect URL containing the issued token details.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "The callback is missing the required `state` or `code` parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "The OIDC login failed, or the callback state is invalid or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "The mapped account is disabled, not provisioned, or the requested OIDC role is not allowed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "OIDC is not enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
