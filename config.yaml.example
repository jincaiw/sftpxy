# SFTPxy Example Configuration
# Copy this file to config.yaml and modify as needed

# Common settings
common:
  service_name: "sftpxy"
  log_level: "info"  # debug, info, warn, error, fatal
  log_path: "./logs/sftpxy.log"
  temp_dir: "./data/tmp"
  plugin_path: "./plugins"
  global_timeout: 300

# SSH/SFTP/SCP server configuration
ssh:
  enabled: true
  listen_address: "0.0.0.0"
  listen_port: 30082
  host_keys:
    - "/var/lib/sftpxy/keys/ssh_host_ed25519_key"  # Production must use a persistent host key; use generate-hostkey to create it
  password_auth: true
  public_key_auth: true
  certificate_auth: false
  max_connections: 100
  login_timeout: 60
  idle_timeout: 300
  scp_enabled: true
  banner: "Welcome to SFTPxy"
  allowed_algorithms: []
  disabled_algorithms: []

# FTP/FTPS server configuration
ftp:
  enabled: false
  listen_address: "0.0.0.0"
  listen_port: 30086
  explicit_tls: true
  tls_cert_file: "/etc/sftpxy/certs/sftpxy.crt"
  tls_key_file: "/etc/sftpxy/certs/sftpxy.key"
  force_control_tls: true
  force_data_tls: true
  passive_port_start: 21000
  passive_port_end: 30199
  nat_external_address: ""  # Set this when the server is behind NAT and passive FTP must advertise a public address
  max_connections: 50
  login_timeout: 60
  idle_timeout: 300

# WebDAV server configuration
webdav:
  enabled: false
  listen_address: "0.0.0.0"
  listen_port: 8081
  base_path: "/"
  tls_cert_file: "/etc/sftpxy/certs/sftpxy.crt"
  tls_key_file: "/etc/sftpxy/certs/sftpxy.key"
  client_cert: false  # Client certificate auth is outside the current production scope

# HTTPD (WebAdmin, WebClient, REST API) configuration
httpd:
  enabled: true
  listen_address: "0.0.0.0"
  listen_port: 30088
  client_listen_port: 30080
  tls_cert_file: "/etc/sftpxy/certs/sftpxy.crt"
  tls_key_file: "/etc/sftpxy/certs/sftpxy.key"
  client_cert: false
  webadmin_enabled: true
  webclient_enabled: true
  rest_api_enabled: true
  openapi_enabled: true
  static_path: "./web/dist"
  template_path: "./web/dist"
  session_secret: "replace-with-a-random-32-char-secret"
  token_expiry: 3600
  cors_origins:
    - "https://files.example.com"
  jwt:
    enabled: true
    secret: ""
    issuer: "sftpxy"
    audience: "sftpxy-api"
    expiry_seconds: 3600
  api_keys:
    - key: "replace-with-a-long-random-api-key"
      subject: "automation-admin"
      role: "admin"
      scopes:
        - "admin"
      description: "automation access"
      enabled: false
  oidc:
    enabled: false
    provider_name: "corp-sso"
    client_id: ""
    client_secret: ""
    issuer_url: ""
    auth_url: ""
    token_url: ""
    user_info_url: ""
    redirect_url: "https://files.example.com/api/v1/auth/oidc/callback"
    scopes:
      - "openid"
      - "profile"
      - "email"
    username_field: "preferred_username"
    email_field: "email"
    role_field: "role"
    role_mappings:
      admin: "admin"
      user: "user"
    allow_admin: false
    allow_user: true
    auto_create_users: true
    user_home_base_dir: "/var/lib/sftpxy/oidc-users"
    insecure_skip_verify: false
  ldap:
    enabled: false
    url: "ldaps://ldap.example.com:636"
    bind_dn: "cn=readonly,dc=example,dc=com"
    bind_password: ""
    base_dn: "dc=example,dc=com"
    user_filter: "(&(objectClass=person)(uid=%s))"
    username_attribute: "uid"
    admin_group_cn: "sftpxy-admins"
    allow_admin: false
    allow_user: true
    auto_create_users: true
    user_home_base_dir: "/var/lib/sftpxy/ldap-users"
    insecure_skip_verify: false

# Data provider (database) configuration
data_provider:
  driver: "sqlite"  # sqlite or mysql
  connection_string: "./data/sftpxy.db"
  ssl_mode: "disable"
  max_open_conns: 25
  max_idle_conns: 5
  conn_max_lifetime: 300
  auto_migrate: true

# Telemetry server configuration
telemetry:
  enabled: true
  listen_address: "0.0.0.0"
  listen_port: 0
  tls_cert_file: ""
  tls_key_file: ""
  enable_profiling: false

# HTTP clients configuration
http_clients:
  default_timeout: 30
  tls_verify: true
  max_connections: 100

# Command execution configuration
commands:
  whitelist:
    - "/usr/local/bin/sftpxy-hook"
  timeout: 30

# KMS (Key Management Service) configuration
kms:
  type: "local"  # local or file
  key_path: "./keys/kms.key"

# MFA (Multi-Factor Authentication) configuration
mfa:
  enabled: false
  issuer: "SFTPxy"
  force_for_admins: false
  force_for_users: false

# SMTP configuration for email notifications
smtp:
  host: "smtp.example.com"
  port: 587
  username: ""
  password: ""
  from: "noreply@example.com"
  use_tls: true

# Plugin configuration
plugins:
  path: "./plugins"
  enabled:
    ldap: false
    geoip: false
